<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hospital.mapper.ChScheduleMapper">
    
    <resultMap type="ChSchedule" id="ChScheduleResult">
        <result property="scheduleId"    column="schedule_id"    />
        <result property="staffId"    column="staff_id"    />
        <result property="scheduleDate"    column="schedule_date"    />
        <result property="timeSlot"    column="time_slot"    />
        <result property="roomNo"    column="room_no"    />
        <result property="maxPatients"    column="max_patients"    />
        <result property="currentPatients"    column="current_patients"    />
        <result property="scheduleType"    column="schedule_type"    />
        <result property="fee"    column="fee"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectChScheduleVo">
        select schedule_id, staff_id, schedule_date, time_slot, room_no, max_patients, current_patients, schedule_type, fee, status, create_by, create_time, update_by, update_time from ch_schedule
    </sql>

    <select id="selectChScheduleList" parameterType="ChSchedule" resultMap="ChScheduleResult">
        <include refid="selectChScheduleVo"/>
        <where>  
            <if test="staffId != null "> and staff_id = #{staffId}</if>
            <if test="scheduleDate != null "> and schedule_date = #{scheduleDate}</if>
            <if test="timeSlot != null  and timeSlot != ''"> and time_slot = #{timeSlot}</if>
            <if test="roomNo != null  and roomNo != ''"> and room_no = #{roomNo}</if>
            <if test="maxPatients != null "> and max_patients = #{maxPatients}</if>
            <if test="currentPatients != null "> and current_patients = #{currentPatients}</if>
            <if test="scheduleType != null  and scheduleType != ''"> and schedule_type = #{scheduleType}</if>
            <if test="fee != null "> and fee = #{fee}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectChScheduleByScheduleId" parameterType="Long" resultMap="ChScheduleResult">
        <include refid="selectChScheduleVo"/>
        where schedule_id = #{scheduleId}
    </select>

    <insert id="insertChSchedule" parameterType="ChSchedule" useGeneratedKeys="true" keyProperty="scheduleId">
        insert into ch_schedule
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="staffId != null">staff_id,</if>
            <if test="scheduleDate != null">schedule_date,</if>
            <if test="timeSlot != null and timeSlot != ''">time_slot,</if>
            <if test="roomNo != null">room_no,</if>
            <if test="maxPatients != null">max_patients,</if>
            <if test="currentPatients != null">current_patients,</if>
            <if test="scheduleType != null">schedule_type,</if>
            <if test="fee != null">fee,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="staffId != null">#{staffId},</if>
            <if test="scheduleDate != null">#{scheduleDate},</if>
            <if test="timeSlot != null and timeSlot != ''">#{timeSlot},</if>
            <if test="roomNo != null">#{roomNo},</if>
            <if test="maxPatients != null">#{maxPatients},</if>
            <if test="currentPatients != null">#{currentPatients},</if>
            <if test="scheduleType != null">#{scheduleType},</if>
            <if test="fee != null">#{fee},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateChSchedule" parameterType="ChSchedule">
        update ch_schedule
        <trim prefix="SET" suffixOverrides=",">
            <if test="staffId != null">staff_id = #{staffId},</if>
            <if test="scheduleDate != null">schedule_date = #{scheduleDate},</if>
            <if test="timeSlot != null and timeSlot != ''">time_slot = #{timeSlot},</if>
            <if test="roomNo != null">room_no = #{roomNo},</if>
            <if test="maxPatients != null">max_patients = #{maxPatients},</if>
            <if test="currentPatients != null">current_patients = #{currentPatients},</if>
            <if test="scheduleType != null">schedule_type = #{scheduleType},</if>
            <if test="fee != null">fee = #{fee},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where schedule_id = #{scheduleId}
    </update>

    <delete id="deleteChScheduleByScheduleId" parameterType="Long">
        delete from ch_schedule where schedule_id = #{scheduleId}
    </delete>

    <delete id="deleteChScheduleByScheduleIds" parameterType="String">
        delete from ch_schedule where schedule_id in 
        <foreach item="scheduleId" collection="array" open="(" separator="," close=")">
            #{scheduleId}
        </foreach>
    </delete>
</mapper>