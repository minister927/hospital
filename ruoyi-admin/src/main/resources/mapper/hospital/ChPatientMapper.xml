<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hospital.mapper.ChPatientMapper">
    
    <resultMap type="ChPatient" id="ChPatientResult">
        <result property="patientId"    column="patient_id"    />
        <result property="userId"    column="user_id"    />
        <result property="patientNo"    column="patient_no"    />
        <result property="idCard"    column="id_card"    />
        <result property="gender"    column="gender"    />
        <result property="birthDate"    column="birth_date"    />
        <result property="age"    column="age"    />
        <result property="bloodType"    column="blood_type"    />
        <result property="marriageStatus"    column="marriage_status"    />
        <result property="occupation"    column="occupation"    />
        <result property="nation"    column="nation"    />
        <result property="address"    column="address"    />
        <result property="phone"    column="phone"    />
        <result property="allergyHistory"    column="allergy_history"    />
        <result property="chronicDisease"    column="chronic_disease"    />
        <result property="familyHistory"    column="family_history"    />
        <result property="insuranceNo"    column="insurance_no"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectChPatientVo">
        select patient_id, user_id, patient_no, id_card, gender, birth_date, age, blood_type, marriage_status, occupation, nation, address, phone, allergy_history, chronic_disease, family_history, insurance_no, status, create_by, create_time, update_by, update_time, remark from ch_patient
    </sql>

    <select id="selectChPatientList" parameterType="ChPatient" resultMap="ChPatientResult">
        <include refid="selectChPatientVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="patientNo != null  and patientNo != ''"> and patient_no = #{patientNo}</if>
            <if test="idCard != null  and idCard != ''"> and id_card = #{idCard}</if>
            <if test="gender != null  and gender != ''"> and gender = #{gender}</if>
            <if test="birthDate != null "> and birth_date = #{birthDate}</if>
            <if test="age != null "> and age = #{age}</if>
            <if test="bloodType != null  and bloodType != ''"> and blood_type = #{bloodType}</if>
            <if test="marriageStatus != null  and marriageStatus != ''"> and marriage_status = #{marriageStatus}</if>
            <if test="occupation != null  and occupation != ''"> and occupation = #{occupation}</if>
            <if test="nation != null  and nation != ''"> and nation = #{nation}</if>
            <if test="address != null  and address != ''"> and address = #{address}</if>
            <if test="phone != null  and phone != ''"> and phone = #{phone}</if>
            <if test="allergyHistory != null  and allergyHistory != ''"> and allergy_history = #{allergyHistory}</if>
            <if test="chronicDisease != null  and chronicDisease != ''"> and chronic_disease = #{chronicDisease}</if>
            <if test="familyHistory != null  and familyHistory != ''"> and family_history = #{familyHistory}</if>
            <if test="insuranceNo != null  and insuranceNo != ''"> and insurance_no = #{insuranceNo}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectChPatientByPatientId" parameterType="Long" resultMap="ChPatientResult">
        <include refid="selectChPatientVo"/>
        where patient_id = #{patientId}
    </select>

    <insert id="insertChPatient" parameterType="ChPatient" useGeneratedKeys="true" keyProperty="patientId">
        insert into ch_patient
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="patientNo != null and patientNo != ''">patient_no,</if>
            <if test="idCard != null">id_card,</if>
            <if test="gender != null">gender,</if>
            <if test="birthDate != null">birth_date,</if>
            <if test="age != null">age,</if>
            <if test="bloodType != null">blood_type,</if>
            <if test="marriageStatus != null">marriage_status,</if>
            <if test="occupation != null">occupation,</if>
            <if test="nation != null">nation,</if>
            <if test="address != null">address,</if>
            <if test="phone != null">phone,</if>
            <if test="allergyHistory != null">allergy_history,</if>
            <if test="chronicDisease != null">chronic_disease,</if>
            <if test="familyHistory != null">family_history,</if>
            <if test="insuranceNo != null">insurance_no,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="patientNo != null and patientNo != ''">#{patientNo},</if>
            <if test="idCard != null">#{idCard},</if>
            <if test="gender != null">#{gender},</if>
            <if test="birthDate != null">#{birthDate},</if>
            <if test="age != null">#{age},</if>
            <if test="bloodType != null">#{bloodType},</if>
            <if test="marriageStatus != null">#{marriageStatus},</if>
            <if test="occupation != null">#{occupation},</if>
            <if test="nation != null">#{nation},</if>
            <if test="address != null">#{address},</if>
            <if test="phone != null">#{phone},</if>
            <if test="allergyHistory != null">#{allergyHistory},</if>
            <if test="chronicDisease != null">#{chronicDisease},</if>
            <if test="familyHistory != null">#{familyHistory},</if>
            <if test="insuranceNo != null">#{insuranceNo},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateChPatient" parameterType="ChPatient">
        update ch_patient
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="patientNo != null and patientNo != ''">patient_no = #{patientNo},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="birthDate != null">birth_date = #{birthDate},</if>
            <if test="age != null">age = #{age},</if>
            <if test="bloodType != null">blood_type = #{bloodType},</if>
            <if test="marriageStatus != null">marriage_status = #{marriageStatus},</if>
            <if test="occupation != null">occupation = #{occupation},</if>
            <if test="nation != null">nation = #{nation},</if>
            <if test="address != null">address = #{address},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="allergyHistory != null">allergy_history = #{allergyHistory},</if>
            <if test="chronicDisease != null">chronic_disease = #{chronicDisease},</if>
            <if test="familyHistory != null">family_history = #{familyHistory},</if>
            <if test="insuranceNo != null">insurance_no = #{insuranceNo},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where patient_id = #{patientId}
    </update>

    <delete id="deleteChPatientByPatientId" parameterType="Long">
        delete from ch_patient where patient_id = #{patientId}
    </delete>

    <delete id="deleteChPatientByPatientIds" parameterType="String">
        delete from ch_patient where patient_id in 
        <foreach item="patientId" collection="array" open="(" separator="," close=")">
            #{patientId}
        </foreach>
    </delete>
</mapper>